<% layout('layouts/boilerplate') -%>

<style>
  /* ===== SHOW PAGE BASE STYLES ===== */
  .show-hero {
    position: relative;
    width: 100%;
    height: 480px;
    border-radius: 24px;
    overflow: hidden;
    margin-bottom: 2rem;
  }

  .show-hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .show-hero:hover img { transform: scale(1.03); }

  .show-hero-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 2.5rem;
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.9));
    border-radius: 0 0 24px 24px;
  }

  .show-hero-title {
    font-size: 2.4rem;
    font-weight: 800;
    color: #fff;
    margin-bottom: 0.3rem;
  }

  .show-hero-meta {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    color: rgba(255, 255, 255, 0.75);
    font-size: 1rem;
  }

  .show-hero-meta i { color: #fe424d; }

  /* ===== PACKING ASSISTANT (ADVANCED FEATURE) ===== */
  .ai-packing-card {
    background: rgba(254, 66, 77, 0.08);
    border: 1px solid rgba(254, 66, 77, 0.2);
    border-radius: 16px;
    padding: 1.5rem;
    margin-bottom: 2rem;
    border-left: 5px solid #fe424d !important;
  }

  /* ===== REVIEWS & CARDS ===== */
  .review-card {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 16px;
    padding: 1.5rem;
    margin-bottom: 1rem;
    transition: 0.2s;
  }

  .review-card:hover { background: rgba(255, 255, 255, 0.06); }

  .booking-card {
    background: #1e1e2e;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 20px;
    padding: 1.5rem;
    position: sticky;
    top: 100px;
  }

  #map {
    height: 350px;
    width: 100%;
    border-radius: 20px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    z-index: 1;
  }

  /* UTILITY */
  .white-pre { white-space: pre-line; }
  .form-control:focus, .form-select:focus {
    background-color: #2b2b3d !important;
    border-color: #fe424d !important;
    box-shadow: none;
    color: white;
  }
</style>

<div class="container mt-3">
  <div class="show-hero">
    <img src="<%= listing.image.url %>" alt="<%= listing.title %>" />
    <div class="show-hero-overlay">
      <div class="show-hero-title"><%= listing.title %></div>
      <div class="show-hero-meta">
        <span><i class="fa-solid fa-location-dot"></i> <%= listing.location %>, <%= listing.country %></span>
      </div>
    </div>
  </div>

  <div class="row show-content">
    <div class="col-lg-8 show-left">
      
      <div class="owner-row d-flex align-items-center mb-4 border-bottom pb-3">
        <div class="owner-avatar me-3 bg-danger text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px; font-weight: bold;">
          <%= (listing.owner ? listing.owner.username : "A")[0].toUpperCase() %>
        </div>
        <div class="owner-info">
          <div class="owner-name text-white fw-bold">Hosted by <%= listing.owner ? listing.owner.username : "Anonymous" %></div>
          <div class="owner-label text-muted small">Professional Host · Verified Listing</div>
        </div>
      </div>

      <p class="show-description text-white-50 mb-4" style="line-height: 1.8; font-size: 1.1rem;">
        <%= listing.description %>
      </p>

      <div class="ai-packing-card">
        <h5 class="text-white mb-2"><i class="fa-solid fa-suitcase-rolling text-danger me-2"></i> Smart Packing Guide</h5>
        <p id="packText" class="text-muted small">Planning a trip? Let AI suggest what to pack for <%= new Intl.DateTimeFormat('en-US', { month: 'long' }).format(new Date()) %>.</p>
        <button id="packBtn" class="btn btn-danger btn-sm rounded-pill px-3">Generate List ✨</button>
        <div id="packResult" class="mt-3 text-white white-pre" style="display:none; font-size: 0.95rem;"></div>
      </div>

      <div class="map-section mb-5">
        <h5 class="text-white mb-3"><i class="fa-solid fa-map-location-dot text-danger me-2"></i> Location Map</h5>
        <div id="map"></div>
      </div>

      <div class="reviews-section">
        <h5 class="text-white mb-4"><i class="fa-solid fa-star text-danger me-2"></i> Guest Reviews (<%= listing.reviews.length %>)</h5>
        
        <% if(listing.reviews.length > 0) { %>
          <div class="row">
            <% for(let review of listing.reviews) { %>
              <div class="col-md-6 mb-3">
                <div class="review-card">
                  <div class="review-header d-flex justify-content-between">
                    <span class="text-white fw-bold"><%= review.author.username %></span>
                    <span class="text-warning small"><%= review.rating %> ★</span>
                  </div>
                  <p class="review-body mt-2 text-white-50 small"><%= review.comment %></p>
                  <% if(currUser && review.author._id.equals(currUser._id)) { %>
                    <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                      <button class="btn btn-sm btn-outline-danger py-0" style="font-size: 0.7rem;">Delete</button>
                    </form>
                  <% } %>
                </div>
              </div>
            <% } %>
          </div>
        <% } else { %>
          <p class="text-muted">No reviews yet. Stay here and leave the first one!</p>
        <% } %>

        <% if(currUser) { %>
          <div class="review-form-card mt-4 p-4 border rounded bg-dark border-secondary">
            <h6 class="text-white mb-3">Leave a Rating</h6>
            <form method="POST" action="/listings/<%= listing._id %>/reviews" novalidate class="needs-validation">
              <fieldset class="starability-basic">
                <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked />
                <input type="radio" id="first-rate1" name="review[rating]" value="1" /><label for="first-rate1">1 star</label>
                <input type="radio" id="first-rate2" name="review[rating]" value="2" /><label for="first-rate2">2 stars</label>
                <input type="radio" id="first-rate3" name="review[rating]" value="3" /><label for="first-rate3">3 stars</label>
                <input type="radio" id="first-rate4" name="review[rating]" value="4" /><label for="first-rate4">4 stars</label>
                <input type="radio" id="first-rate5" name="review[rating]" value="5" /><label for="first-rate5">5 stars</label>
              </fieldset>
              <textarea name="review[comment]" class="form-control bg-dark text-white border-secondary mb-3" rows="3" required placeholder="Share your experience..."></textarea>
              <button class="btn btn-danger px-4 fw-bold">Post Review</button>
            </form>
          </div>
        <% } %>
      </div>
    </div>

    <div class="col-lg-4">
      <div class="booking-card shadow-lg">
        <div class="booking-price">
          <span class="fs-2 fw-bold text-white">₹<%= listing.price.toLocaleString("en-IN") %></span>
          <span class="text-muted fs-6"> / night</span>
        </div>
        
        <hr class="border-secondary opacity-25">

        <form method="POST" action="/listings/<%= listing._id %>/book">
          
          <div class="mb-3">
            <label class="text-white-50 small fw-bold mb-1">Check-in</label>
            <input type="date" name="checkIn" required class="form-control bg-dark text-white border-secondary py-2">
          </div>

          <div class="mb-3">
            <label class="text-white-50 small fw-bold mb-1">Check-out</label>
            <input type="date" name="checkOut" required class="form-control bg-dark text-white border-secondary py-2">
          </div>

          <div class="mb-3">
            <label class="text-white-50 small fw-bold mb-1">Guests</label>
            <select name="guests" class="form-select bg-dark text-white border-secondary py-2">
              <option value="1">1 Guest</option>
              <option value="2">2 Guests</option>
              <option value="3">3 Guests</option>
              <option value="4">4 Guests</option>
            </select>
          </div>

          <div class="d-flex justify-content-between mb-2 text-white-50 small">
            <span>Service fee (12%)</span>
            <span>₹<%= Math.round(listing.price * 0.12).toLocaleString("en-IN") %></span>
          </div>
          
          <div class="d-flex justify-content-between mb-3 fw-bold text-white fs-5 pt-2 border-top border-secondary">
            <span>Total</span>
            <span class="text-danger">₹<%= Math.round(listing.price * 1.12).toLocaleString("en-IN") %></span>
          </div>

         <% if(currUser) { %>
  <button type="submit" class="btn btn-danger w-100 py-3 fw-bold rounded-3">
    <i class="fa-solid fa-calendar-check me-2"></i> Reserve Now
  </button>

  <!-- ✅ ADD HERE -->
   
  <button type="button"
        onclick="payNow(<%= Math.round(listing.price * 1.12) %>, this)"
        class="pay-btn mt-2">
  <i class="fa-solid fa-credit-card"></i>
  Pay Securely
</button>

<% } else { %>

  <a href="/login" class="btn btn-outline-danger w-100 py-3 fw-bold rounded-3">
    Login to Reserve
  </a>

<% } %>

        <% if(currUser && listing.owner && currUser._id.equals(listing.owner._id)) { %>
          <div class="d-flex gap-2 mt-3">
            <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark flex-grow-1 border-secondary py-2">Edit</a>
            <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST" class="flex-grow-1">
              <button class="btn btn-outline-secondary w-100 py-2">Delete</button>
            </form>
          </div>
        <% } %>
        
        <p class="text-center text-muted small mt-3">You won't be charged yet.</p>
      </div>
    </div>
  </div>
</div>

<script>
  // 1. DATA PASSING
  const listingData = <%- JSON.stringify(listing) %>;
  const currentListingName = "<%= listing.title %>"; 

  // 2. MAP LOGIC
  let lat = 28.6139, lng = 77.209; // Default coords
  if (listingData.geometry?.coordinates?.length === 2) {
    [lng, lat] = listingData.geometry.coordinates;
  }

  const map = L.map("map").setView([lat, lng], 11);
  L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
    attribution: '&copy; OpenStreetMap'
  }).addTo(map);

  L.marker([lat, lng]).addTo(map).bindPopup(`<b>${listingData.title}</b><br>${listingData.location}`).openPopup();

  // 3. AI PACKING ASSISTANT LOGIC
  document.getElementById("packBtn").addEventListener("click", async () => {
    const btn = document.getElementById("packBtn");
    const resultDiv = document.getElementById("packResult");
    
    btn.innerText = "Consulting AI... ✨";
    try {
      const res = await fetch(`/listings/<%= listing._id %>/smart-pack`);
      if(!res.ok) throw new Error();
      const data = await res.json();
      resultDiv.style.display = "block";
      resultDiv.innerHTML = `<strong>AI Suggestions for ${data.month}:</strong><br>${data.advice}`;
      btn.style.display = "none";
    } catch(err) {
      btn.innerText = "Try again later!";
      console.log("Error:", err);
    }
  });

  // Fix for map display
  setTimeout(() => map.invalidateSize(), 400);
</script>
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>

</script>  <!-- existing script end -->

<!-- ✅ YAHAN PASTE KARNA HAI -->
 <script>
async function payNow(amount, btn) {

  btn.innerHTML = "Processing...";
  btn.disabled = true;

  try {
    const res = await fetch("/payment/create-order", {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({ amount: Number(amount) })
    });

    const order = await res.json();

    const options = {
      key: "rzp_test_ShPoD3FdLFkNyC",
      amount: order.amount,
      currency: "INR",
      name: "Wanderlust",
      description: "Booking Payment",
      order_id: order.id,

      handler: function () {
        alert("Payment Successful 🎉");
      },

      modal: {
        ondismiss: function () {
          console.log("User closed payment");
        }
      }
    };

    const rzp = new Razorpay(options);
    rzp.open();

  } catch (err) {
    console.log("ERROR:", err);
    alert("Payment failed");
  } finally {
    // 🔥 ALWAYS RESET BUTTON
    btn.innerHTML = '<i class="fa-solid fa-credit-card"></i> Pay Securely';
    btn.disabled = false;
  }
}
</script>