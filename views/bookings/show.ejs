<% layout('layouts/boilerplate') -%>

<style>
  .booking-confirm-wrap {
    max-width: 650px;
    margin: 3rem auto;
  }

  .booking-confirm-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 24px;
    overflow: hidden;
  }

  .booking-confirm-header {
    background: linear-gradient(135deg, #fe424d, #ff6b35);
    padding: 2rem;
    text-align: center;
  }

  .booking-confirm-header i {
    font-size: 3rem;
    color: #fff;
    margin-bottom: 0.5rem;
    display: block;
  }

  .booking-confirm-header h2 {
    color: #fff;
    font-weight: 800;
    margin: 0;
  }

  .booking-confirm-header p {
    color: rgba(255,255,255,0.8);
    margin: 0.3rem 0 0;
    font-size: 0.9rem;
  }

  .booking-confirm-body {
    padding: 2rem;
  }

  .booking-info-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.9rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    font-size: 0.9rem;
  }

  .booking-info-row:last-child {
    border-bottom: none;
  }

  .booking-info-label {
    color: rgba(255,255,255,0.45);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .booking-info-label i {
    color: #fe424d;
    width: 16px;
  }

  .booking-info-value {
    color: #fff;
    font-weight: 600;
  }

  .booking-total-row {
    background: rgba(254,66,77,0.08);
    border: 1px solid rgba(254,66,77,0.2);
    border-radius: 12px;
    padding: 1rem 1.2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 1rem;
  }

  .booking-total-label {
    color: #fff;
    font-weight: 700;
    font-size: 1rem;
  }

  .booking-total-value {
    color: #fe424d;
    font-weight: 800;
    font-size: 1.3rem;
  }

  .booking-status {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3rem 0.8rem;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
  }

  .status-confirmed {
    background: rgba(25,195,125,0.15);
    color: #19c37d;
    border: 1px solid rgba(25,195,125,0.3);
  }

  .status-cancelled {
    background: rgba(254,66,77,0.15);
    color: #fe424d;
    border: 1px solid rgba(254,66,77,0.3);
  }

  .btn-back {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    color: #fff;
    border-radius: 10px;
    padding: 0.6rem 1.2rem;
    text-decoration: none;
    font-size: 0.88rem;
    font-weight: 600;
    transition: all 0.2s ease;
    margin-top: 1.5rem;
    margin-right: 0.5rem;
  }

  .btn-back:hover {
    background: rgba(255,255,255,0.1);
    color: #fff;
  }

  .btn-cancel-booking {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(254,66,77,0.1);
    border: 1px solid rgba(254,66,77,0.3);
    color: #fe424d;
    border-radius: 10px;
    padding: 0.6rem 1.2rem;
    font-size: 0.88rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
    margin-top: 1.5rem;
  }

  .btn-cancel-booking:hover {
    background: #fe424d;
    color: #fff;
  }
</style>

<div class="booking-confirm-wrap">
  <div class="booking-confirm-card">

    <!-- HEADER -->
    <div class="booking-confirm-header">
      <i class="fa-solid fa-circle-check"></i>
      <h2>Booking Confirmed!</h2>
      <p>Your reservation has been successfully placed</p>
    </div>

    <!-- BODY -->
    <div class="booking-confirm-body">

      <div class="booking-info-row">
        <span class="booking-info-label"><i class="fa-solid fa-house"></i> Property</span>
        <span class="booking-info-value"><%= booking.listing.title %></span>
      </div>

      <div class="booking-info-row">
        <span class="booking-info-label"><i class="fa-solid fa-location-dot"></i> Location</span>
        <span class="booking-info-value"><%= booking.listing.location %>, <%= booking.listing.country %></span>
      </div>

      <div class="booking-info-row">
        <span class="booking-info-label"><i class="fa-solid fa-calendar-check"></i> Check-in</span>
        <span class="booking-info-value"><%= new Date(booking.checkIn).toDateString() %></span>
      </div>

      <div class="booking-info-row">
        <span class="booking-info-label"><i class="fa-solid fa-calendar-xmark"></i> Check-out</span>
        <span class="booking-info-value"><%= new Date(booking.checkOut).toDateString() %></span>
      </div>

      <div class="booking-info-row">
        <span class="booking-info-label"><i class="fa-solid fa-users"></i> Guests</span>
        <span class="booking-info-value"><%= booking.guests %> guest(s)</span>
      </div>

      <div class="booking-info-row">
        <span class="booking-info-label"><i class="fa-solid fa-circle-dot"></i> Status</span>
        <span class="booking-status <%= booking.status === 'confirmed' ? 'status-confirmed' : 'status-cancelled' %>">
          <i class="fa-solid fa-circle"></i> <%= booking.status.charAt(0).toUpperCase() + booking.status.slice(1) %>
        </span>
      </div>

      <div class="booking-total-row">
        <span class="booking-total-label">Total Amount (incl. taxes)</span>
        <span class="booking-total-value">₹<%= booking.totalPrice.toLocaleString("en-IN") %></span>
      </div>

      <!-- ACTIONS -->
      <div>
        <a href="/listings/<%= booking.listing._id %>" class="btn-back">
          <i class="fa-solid fa-arrow-left"></i> Back to Listing
        </a>
        <a href="/bookings" class="btn-back">
          <i class="fa-solid fa-list"></i> My Bookings
        </a>
        <% if(booking.status === "confirmed") { %>
          <form method="POST" action="/bookings/<%= booking._id %>/cancel" style="display:inline;">
            <button class="btn-cancel-booking" type="submit">
              <i class="fa-solid fa-xmark"></i> Cancel Booking
            </button>
          </form>
        <% } %>
      </div>

    </div>
  </div>
</div>